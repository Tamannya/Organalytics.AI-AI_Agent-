<!DOCTYPE html>
<html lang="en" class="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>AI Organizational Analytics Dashboard</title>
  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <!-- Tailwind CSS -->
  <script src="https://cdn.tailwindcss.com"></script>
  <!-- Chart.js -->
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <!-- Lucide Icons -->
  <script src="https://unpkg.com/lucide@latest"></script>
  <!-- Axios -->
  <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
  <!-- html2pdf.js for client-side high-quality PDF downloads -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
  
  <script>
    tailwind.config = {
      darkMode: 'class',
      theme: {
        extend: {
          colors: {
            darkBg: '#000000',
            darkCard: '#0A0514', // Midnight Purple-Black
            darkBorder: '#1F0F3E', // Deep Violet Border
            midnightPurple: '#250F4F', // Top color from palette
            mediumPurple: '#512E8B', // Second color
            royalBlue: '#3F7FDE', // Third color
            softBlue: '#8DA8FF' // Bottom color
          },
          fontFamily: {
            sans: ['Inter', 'sans-serif'],
            outfit: ['Outfit', 'sans-serif'],
          }
        }
      }
    }
  </script>
  <style>
    :root {
      --primary: #7C6FFF;
      --accent: #8DA8FF;
      --bg: #000000;
      --card-bg: rgba(10, 5, 20, 0.85);
      --text-primary: #E5E7EB;
      --text-secondary: #9CA3AF;
      --border: rgba(141, 168, 255, 0.08);
      
      --chart-1: #7C6FFF;
      --chart-2: #3F7FDE;
      --chart-3: #8DA8FF;
      --chart-4: #EC4899;
      --chart-5: #F59E0B;
      --chart-6: #10B981;
    }

    body {
      background-color: var(--bg);
      color: var(--text-primary);
      font-family: 'Inter', sans-serif;
      transition: background-color 0.25s ease, color 0.25s ease;
    }
    .font-outfit {
      font-family: 'Outfit', sans-serif;
    }
    .glass-panel {
      background: var(--card-bg);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border: 1px solid var(--border);
      transition: background 0.25s ease, border-color 0.25s ease;
    }
    .glass-panel-hover:hover {
      background: rgba(31, 15, 62, 0.95);
      border-color: rgba(141, 168, 255, 0.4);
      box-shadow: 0 0 25px rgba(81, 46, 139, 0.2);
      transform: translateY(-2px);
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .glow-border {
      box-shadow: 0 0 15px rgba(81, 46, 139, 0.15);
      border-color: rgba(81, 46, 139, 0.4);
    }
    .glow-border-blue {
      box-shadow: 0 0 15px rgba(63, 127, 222, 0.15);
      border-color: rgba(63, 127, 222, 0.4);
    }
    .text-gradient {
      background: linear-gradient(to right, #8DA8FF, #512E8B);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }
    .text-gradient-blue {
      background: linear-gradient(to right, #3F7FDE, #8DA8FF);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }
    ::-webkit-scrollbar {
      width: 6px;
      height: 6px;
    }
    ::-webkit-scrollbar-track {
      background: var(--bg);
    }
    ::-webkit-scrollbar-thumb {
      background: var(--border);
      border-radius: 3px;
    }
    ::-webkit-scrollbar-thumb:hover {
      background: var(--primary);
    }
    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(8px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .animate-fade-in {
      animation: fadeIn 0.4s ease-out forwards;
    }
    /* Animated floating elements */
    @keyframes float1 {
      0% { transform: translateY(0px) rotate(0deg); }
      50% { transform: translateY(-20px) rotate(180deg); }
      100% { transform: translateY(0px) rotate(360deg); }
    }
    @keyframes float2 {
      0% { transform: translateY(0px) scale(1); }
      50% { transform: translateY(15px) scale(1.1); }
      100% { transform: translateY(0px) scale(1); }
    }
    .floating-blob-1 {
      animation: float1 15s infinite ease-in-out;
    }
    .floating-blob-2 {
      animation: float2 12s infinite ease-in-out;
    }
    /* SVG Pipeline dash animation */
    @keyframes dash {
      to {
        stroke-dashoffset: -40;
      }
    }
    .animate-dash {
      stroke-dasharray: 8, 12;
      animation: dash 3s linear infinite;
    }
    /* Scroll Animation */
    .scroll-animate {
      opacity: 0;
      transform: translateY(20px);
      transition: opacity 0.6s ease-out, transform 0.6s ease-out;
    }
    .scroll-animate.visible {
      opacity: 1;
      transform: translateY(0);
    }
  </style>
</head>
<body class="overflow-x-hidden min-h-screen relative">

  <!-- ==================== ANIMATED FLOATING BACKGROUND GRAPHICS ==================== -->
  <div class="absolute top-1/4 left-10 w-96 h-96 bg-midnightPurple/10 rounded-full filter blur-[120px] floating-blob-1 pointer-events-none -z-10"></div>
  <div class="absolute bottom-1/3 right-10 w-[450px] h-[450px] bg-royalBlue/10 rounded-full filter blur-[150px] floating-blob-2 pointer-events-none -z-10"></div>

  <!-- ==================== MAIN APP ROOT ==================== -->
  <div id="app-root" class="relative z-10">

    <!-- LANDING VIEW -->
    <div id="view-landing" class="min-h-screen relative overflow-y-auto scroll-smooth flex flex-col justify-between">
      
      <!-- HEADER -->
      <header class="max-w-7xl mx-auto w-full px-6 py-6 flex items-center justify-between border-b border-darkBorder/40">
        <div class="flex items-center space-x-3">
          <div class="h-9 w-9 rounded-lg bg-gradient-to-tr from-mediumPurple via-royalBlue to-softBlue flex items-center justify-center shadow-lg">
            <i data-lucide="bar-chart-3" class="h-5 w-5 text-white"></i>
          </div>
          <div>
            <span class="font-outfit font-extrabold text-lg text-white block tracking-wide">ORGANALYTICS</span>
            <span class="text-[9px] text-softBlue font-mono font-bold tracking-widest uppercase block">AI Audit Engine</span>
          </div>
        </div>
        <button onclick="switchView('auth')" class="px-5 py-2 rounded-xl bg-darkCard border border-darkBorder hover:border-softBlue/40 text-gray-200 text-sm font-semibold transition-all duration-200 shadow-md">
          Sign In
        </button>
      </header>

      <!-- SECTION 1: HERO -->
      <section id="landing-hero" class="max-w-7xl mx-auto w-full px-6 py-12 flex flex-col lg:flex-row items-center justify-between gap-12 min-h-[75vh]">
        <div class="flex-1 text-center lg:text-left space-y-6">
          <div class="inline-flex items-center space-x-2 bg-darkCard/80 border border-darkBorder px-3.5 py-1.5 rounded-full text-xs font-semibold text-softBlue glow-border">
            <span class="h-2 w-2 rounded-full bg-softBlue animate-ping"></span>
            <span>Next-Generation Corporate Diagnostics</span>
          </div>
          <h2 class="text-4xl lg:text-6xl font-outfit font-extrabold text-white leading-tight">
            Transform Raw Data into <span class="text-gradient">Strategic Growth</span>
          </h2>
          <p class="text-gray-400 text-lg max-w-xl mx-auto lg:mx-0">
            Upload your financial spreadsheet and describe your organizational goals. Our Gemini-powered engine instantly models forecasts, isolates operational anomalies, and drafts exportable strategic audits.
          </p>
          <div class="pt-4 flex flex-col sm:flex-row items-center justify-center lg:justify-start gap-4">
            <button onclick="switchView('auth')" class="w-full sm:w-auto px-8 py-4 rounded-xl bg-gradient-to-r from-mediumPurple via-royalBlue to-softBlue text-white font-bold flex items-center justify-center space-x-3 shadow-lg hover:opacity-95 transition-all duration-200">
              <span>Get Started Free</span>
              <i data-lucide="arrow-right" class="h-5 w-5"></i>
            </button>
            <button onclick="document.getElementById('landing-features').scrollIntoView({behavior: 'smooth'})" class="w-full sm:w-auto px-8 py-4 rounded-xl border border-darkBorder hover:border-softBlue/40 text-gray-300 font-semibold flex items-center justify-center space-x-2 transition-all">
              <span>Explore Features</span>
              <i data-lucide="chevron-down" class="h-5 w-5"></i>
            </button>
          </div>
        </div>

        <div class="flex-1 flex justify-center items-center w-full max-w-xl mx-auto">
          <!-- Premium visual dashboard teaser mock -->
          <div class="glass-panel p-6 rounded-3xl border border-darkBorder/60 shadow-2xl relative w-full overflow-hidden glow-border">
            <div class="absolute top-0 left-0 w-full h-[3px] bg-gradient-to-r from-mediumPurple via-royalBlue to-softBlue animate-pulse"></div>
            <div class="flex justify-between items-center mb-6">
              <div class="flex space-x-1.5">
                <span class="w-3 h-3 rounded-full bg-rose-500/80"></span>
                <span class="w-3 h-3 rounded-full bg-amber-500/80"></span>
                <span class="w-3 h-3 rounded-full bg-emerald-500/80"></span>
              </div>
              <span class="text-[10px] text-softBlue font-mono font-bold tracking-widest bg-midnightPurple/30 border border-midnightPurple/50 px-2.5 py-0.5 rounded-full">SYSTEM AUDIT ACTIVE</span>
            </div>
            
            <div class="space-y-4">
              <!-- Mock KPI mini cards -->
              <div class="grid grid-cols-2 gap-4">
                <div class="p-4 bg-black border border-darkBorder rounded-xl">
                  <span class="text-[10px] text-gray-500 block uppercase font-bold">Revenue Run-rate</span>
                  <span class="text-xl font-bold font-outfit text-white block mt-1">$4,850,000</span>
                  <span class="text-[9px] text-emerald-400 font-semibold block mt-0.5">+14.2% YoY</span>
                </div>
                <div class="p-4 bg-black border border-darkBorder rounded-xl">
                  <span class="text-[10px] text-gray-500 block uppercase font-bold">Audit Score</span>
                  <span class="text-xl font-bold font-outfit text-softBlue block mt-1">82 / 100</span>
                  <span class="text-[9px] text-gray-500 block mt-0.5">High Efficiency</span>
                </div>
              </div>
              
              <!-- Mock line chart SVG -->
              <div class="p-4 bg-black border border-darkBorder rounded-xl h-36 flex flex-col justify-between">
                <div class="flex justify-between items-center">
                  <span class="text-[10px] text-gray-400 font-bold">6-Month Trend & ARIMA Projection</span>
                  <div class="flex space-x-3 text-[8px] text-gray-500">
                    <span class="flex items-center"><span class="w-1.5 h-1.5 rounded-full bg-royalBlue mr-1"></span>History</span>
                    <span class="flex items-center"><span class="w-1.5 h-1.5 rounded-full bg-softBlue mr-1"></span>Forecast</span>
                  </div>
                </div>
                <div class="flex-grow flex items-end justify-between relative mt-2">
                  <!-- Visual Grid lines -->
                  <div class="absolute inset-0 flex flex-col justify-between pointer-events-none opacity-10">
                    <div class="border-b border-white w-full"></div>
                    <div class="border-b border-white w-full"></div>
                    <div class="border-b border-white w-full"></div>
                  </div>
                  <!-- SVG projection paths -->
                  <svg class="w-full h-full" viewBox="0 0 100 40" preserveAspectRatio="none">
                    <path d="M 0 35 L 20 28 L 40 32 L 60 22 L 80 15 L 100 8" fill="none" stroke="#3F7FDE" stroke-width="2.5" />
                    <path d="M 60 22 L 80 18 L 100 12" fill="none" stroke="#8DA8FF" stroke-width="2" stroke-dasharray="3,3" />
                  </svg>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- SECTION 2: ANIMATED FEATURE CARDS -->
      <section id="landing-features" class="max-w-7xl mx-auto w-full px-6 py-20 border-t border-darkBorder/30">
        <div class="text-center max-w-2xl mx-auto space-y-4 mb-16">
          <span class="text-xs font-bold text-softBlue uppercase tracking-widest font-mono">Platform Capabilities</span>
          <h3 class="text-3xl lg:text-4xl font-outfit font-extrabold text-white">Full-Stack Business Intelligence</h3>
          <p class="text-gray-400 text-sm leading-relaxed">
            Organalytics incorporates advanced statistics, linear regressions, rolling anomaly checkers, and generative strategy execution.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <!-- Card 1 -->
          <div class="glass-panel p-8 rounded-3xl border border-darkBorder/50 shadow-md glass-panel-hover scroll-animate flex flex-col justify-between h-[360px]">
            <div>
              <div class="h-12 w-12 rounded-xl bg-mediumPurple/15 border border-mediumPurple/30 flex items-center justify-center text-softBlue mb-6">
                <i data-lucide="cpu" class="h-6 w-6"></i>
              </div>
              <h3 class="font-outfit font-bold text-white text-lg">Gemini Strategic Engine</h3>
              <p class="text-gray-400 text-xs mt-3 leading-relaxed">
                Interprets business pain points to configure target KPI dashboards, compile comprehensive SWOT summaries, and write prioritized action plans.
              </p>
            </div>
            <!-- Animated chatbot logic preview -->
            <div class="mt-4 p-3 bg-black/60 border border-darkBorder rounded-xl font-mono text-[9px] space-y-1.5 h-20 overflow-hidden relative">
              <div class="flex items-center space-x-1.5 text-softBlue">
                <span class="w-1.5 h-1.5 rounded-full bg-softBlue animate-ping"></span>
                <span>gemini-pro > pipeline_active</span>
              </div>
              <div class="text-gray-400 border-l border-mediumPurple pl-2 py-0.5 leading-normal animate-pulse">
                Analyzing requirements... Isolated 14.2% YoY growth potential via CRM conversion optimization.
              </div>
            </div>
          </div>

          <!-- Card 2 -->
          <div class="glass-panel p-8 rounded-3xl border border-darkBorder/50 shadow-md glass-panel-hover scroll-animate flex flex-col justify-between h-[360px]">
            <div>
              <div class="h-12 w-12 rounded-xl bg-royalBlue/15 border border-royalBlue/30 flex items-center justify-center text-softBlue mb-6">
                <i data-lucide="line-chart" class="h-6 w-6"></i>
              </div>
              <h3 class="font-outfit font-bold text-white text-lg">Predictive ARIMA Modeling</h3>
              <p class="text-gray-400 text-xs mt-3 leading-relaxed">
                Aggregates historical transactions, isolates underlying seasonal trends, and projects future revenue cycles with standard deviation spreads.
              </p>
            </div>
            <!-- Animated ARIMA graph preview -->
            <div class="mt-4 p-3 bg-black/60 border border-darkBorder rounded-xl h-20 flex flex-col justify-end relative overflow-hidden">
              <div class="absolute top-2 left-2 text-[8px] text-gray-500 font-mono">6-MONTH ARIMA FORECAST</div>
              <svg class="w-full h-10 overflow-visible" viewBox="0 0 100 30" preserveAspectRatio="none">
                <path d="M 0 25 Q 25 15 50 20 T 100 5" fill="none" stroke="#3F7FDE" stroke-width="1.5" />
                <path d="M 50 20 T 100 5" fill="none" stroke="#8DA8FF" stroke-width="1.5" stroke-dasharray="2,2" />
                <!-- Shaded confidence interval -->
                <path d="M 50 20 L 75 14 L 100 0 L 100 14 L 75 24 Z" fill="rgba(141, 168, 255, 0.08)" />
              </svg>
              <div class="flex justify-between text-[7px] text-gray-500 font-mono mt-1">
                <span>Historical Run</span>
                <span>Upper/Lower CI bounds</span>
              </div>
            </div>
          </div>

          <!-- Card 3 -->
          <div class="glass-panel p-8 rounded-3xl border border-darkBorder/50 shadow-md glass-panel-hover scroll-animate flex flex-col justify-between h-[360px]">
            <div>
              <div class="h-12 w-12 rounded-xl bg-softBlue/15 border border-softBlue/30 flex items-center justify-center text-softBlue mb-6">
                <i data-lucide="shield-alert" class="h-6 w-6"></i>
              </div>
              <h3 class="font-outfit font-bold text-white text-lg">Z-Score Outlier Checks</h3>
              <p class="text-gray-400 text-xs mt-3 leading-relaxed">
                Runs statistical anomaly sweeps across your departmental ledgers to isolate abnormal cost overrides and revenue drops.
              </p>
            </div>
            <!-- Animated Z-score bars preview -->
            <div class="mt-4 p-3 bg-black/60 border border-darkBorder rounded-xl h-20 flex items-center justify-around relative overflow-hidden">
              <div class="absolute top-2 left-2 text-[8px] text-gray-500 font-mono font-bold">OUTLIER ALERTS</div>
              <!-- Bar 1 -->
              <div class="flex flex-col items-center justify-end h-10 w-4">
                <div class="bg-royalBlue/40 w-full rounded-t-sm" style="height: 40%"></div>
                <span class="text-[6px] text-gray-500 mt-1">R&D</span>
              </div>
              <!-- Bar 2 Anomaly -->
              <div class="flex flex-col items-center justify-end h-10 w-4 relative">
                <span style="font-size: 6px;" class="absolute -top-3 text-[6px] text-rose-400 font-bold animate-bounce">Z>2.8</span>
                <div class="bg-rose-500 w-full rounded-t-sm animate-pulse shadow-[0_0_8px_rgba(244,63,94,0.5)]" style="height: 90%"></div>
                <span class="text-[6px] text-rose-400 font-bold mt-1">Mkt</span>
              </div>
              <!-- Bar 3 -->
              <div class="flex flex-col items-center justify-end h-10 w-4">
                <div class="bg-royalBlue/40 w-full rounded-t-sm" style="height: 25%"></div>
                <span class="text-[6px] text-gray-500 mt-1">HR</span>
              </div>
              <!-- Bar 4 -->
              <div class="flex flex-col items-center justify-end h-10 w-4">
                <div class="bg-royalBlue/40 w-full rounded-t-sm" style="height: 55%"></div>
                <span class="text-[6px] text-gray-500 mt-1">Ops</span>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- SECTION 3: HOW IT WORKS PREVIEW -->
      <section id="landing-pipeline" class="max-w-7xl mx-auto w-full px-6 py-20 border-t border-darkBorder/30">
        <div class="flex flex-col md:flex-row justify-between items-center border-b border-darkBorder/40 pb-6 mb-16 gap-4">
          <div>
            <h2 class="text-3xl font-extrabold font-outfit text-white tracking-tight">How the Analytics Engine Works</h2>
            <p class="text-sm text-gray-500 mt-1">Stunning visual data pipeline explaining the dashboard creation process</p>
          </div>
          <span class="text-xs font-mono font-bold text-softBlue bg-[#250F4F]/40 border border-darkBorder px-3 py-1.5 rounded-full">Gemini 3.5 Engine</span>
        </div>

        <!-- Flowchart container -->
        <div class="glass-panel p-8 rounded-3xl border border-darkBorder/50 shadow-xl space-y-8 scroll-animate">
          <!-- Animated pipeline row -->
          <div class="relative hidden lg:block overflow-visible py-10 my-4">
            <!-- Connecting glowing SVG paths with animated sliding packets -->
            <svg viewBox="0 0 1000 4" class="absolute top-1/2 left-0 w-full h-1 -translate-y-1/2 -z-10 overflow-visible" fill="none" xmlns="http://www.w3.org/2000/svg">
              <!-- Dotted base line from Node 1 to Node 6 -->
              <path d="M 40 2 L 960 2" stroke="#1F0F3E" stroke-width="4" stroke-dasharray="8,12" />
              <path class="animate-dash" d="M 40 2 L 960 2" stroke="#8DA8FF" stroke-width="3" />
              
              <!-- sliding packets running the entire length -->
              <circle r="4" fill="#54E1EF" style="filter: drop-shadow(0 0 6px #54E1EF)">
                <animateMotion dur="4s" repeatCount="indefinite" path="M 40 2 L 960 2" />
              </circle>
              <circle r="4" fill="#8DA8FF" style="filter: drop-shadow(0 0 6px #8DA8FF)">
                <animateMotion dur="4s" begin="2s" repeatCount="indefinite" path="M 40 2 L 960 2" />
              </circle>
            </svg>

            <div class="flex justify-between px-2">
              <!-- Node 1 -->
              <div class="flex flex-col items-center space-y-3 w-36 transition-all duration-300 transform hover:-translate-y-2 group">
                <div class="h-12 w-12 rounded-full border-2 border-softBlue bg-[#000000] flex items-center justify-center text-softBlue font-bold font-outfit shadow-lg group-hover:border-[#54E1EF] group-hover:shadow-[0_0_15px_rgba(84,225,239,0.3)] transition-all cursor-pointer"><i data-lucide="target" class="h-5 w-5"></i></div>
                <span class="text-xs font-bold text-white tracking-wide text-center">1. Define Goals</span>
                <span style="font-size: 9px;" class="text-gray-500 text-center leading-relaxed">AI chatbot records organization profile</span>
              </div>

              <!-- Node 2 -->
              <div class="flex flex-col items-center space-y-3 w-36 transition-all duration-300 transform hover:-translate-y-2 group">
                <div class="h-12 w-12 rounded-full border-2 border-mediumPurple bg-[#000000] flex items-center justify-center text-softBlue font-bold font-outfit shadow-lg group-hover:border-softBlue group-hover:shadow-[0_0_15px_rgba(141,168,255,0.3)] transition-all cursor-pointer"><i data-lucide="upload-cloud" class="h-5 w-5"></i></div>
                <span class="text-xs font-bold text-white tracking-wide text-center">2. Ingest Ledger</span>
                <span style="font-size: 9px;" class="text-gray-500 text-center leading-relaxed">Drop CSV sheet or load demo database</span>
              </div>

              <!-- Node 3 -->
              <div class="flex flex-col items-center space-y-3 w-36 transition-all duration-300 transform hover:-translate-y-2 group">
                <div class="h-12 w-12 rounded-full border-2 border-royalBlue bg-[#000000] flex items-center justify-center text-softBlue font-bold font-outfit shadow-lg group-hover:border-royalBlue group-hover:shadow-[0_0_15px_rgba(63,127,222,0.3)] transition-all cursor-pointer"><i data-lucide="activity" class="h-5 w-5"></i></div>
                <span class="text-xs font-bold text-white tracking-wide text-center">3. Anomaly Scan</span>
                <span style="font-size: 9px;" class="text-gray-500 text-center leading-relaxed">Compute z-scores for spending deviations</span>
              </div>

              <!-- Node 4 -->
              <div class="flex flex-col items-center space-y-3 w-36 transition-all duration-300 transform hover:-translate-y-2 group">
                <div class="h-12 w-12 rounded-full border-2 border-softBlue bg-[#000000] flex items-center justify-center text-softBlue font-bold font-outfit shadow-lg group-hover:border-softBlue group-hover:shadow-[0_0_15px_rgba(141,168,255,0.3)] transition-all cursor-pointer"><i data-lucide="trending-up" class="h-5 w-5"></i></div>
                <span class="text-xs font-bold text-white tracking-wide text-center">4. Forecast Models</span>
                <span style="font-size: 9px;" class="text-gray-500 text-center leading-relaxed">6-month ARIMA projection curves</span>
              </div>

              <!-- Node 5 -->
              <div class="flex flex-col items-center space-y-3 w-36 transition-all duration-300 transform hover:-translate-y-2 group">
                <div class="h-12 w-12 rounded-full border-2 border-mediumPurple bg-[#000000] flex items-center justify-center text-softBlue font-bold font-outfit shadow-lg group-hover:border-mediumPurple group-hover:shadow-[0_0_15px_rgba(81,46,139,0.3)] transition-all cursor-pointer"><i data-lucide="sparkles" class="h-5 w-5"></i></div>
                <span class="text-xs font-bold text-white tracking-wide text-center">5. AI Strategy</span>
                <span style="font-size: 9px;" class="text-gray-500 text-center leading-relaxed">Gemini audits metrics & structures SWOT</span>
              </div>

              <!-- Node 6 -->
              <div class="flex flex-col items-center space-y-3 w-36 transition-all duration-300 transform hover:-translate-y-2 group">
                <div class="h-12 w-12 rounded-full bg-gradient-to-tr from-mediumPurple to-softBlue flex items-center justify-center text-white font-bold font-outfit shadow-lg group-hover:shadow-[0_0_15px_rgba(141,168,255,0.5)] transition-all cursor-pointer"><i data-lucide="sliders" class="h-5 w-5"></i></div>
                <span class="text-xs font-bold text-white tracking-wide text-center">6. Interactive View</span>
                <span style="font-size: 9px;" class="text-gray-500 text-center leading-relaxed">Adjust simulator variables & export PDF</span>
              </div>
            </div>
          </div>

          <!-- Mobile Grid (Vertical) -->
          <div class="grid grid-cols-1 md:grid-cols-2 lg:hidden gap-6">
            <div class="p-4 bg-black border border-darkBorder rounded-2xl flex items-center space-x-4">
              <div class="h-9 w-9 rounded-full bg-softBlue/10 text-softBlue flex items-center justify-center font-bold">1</div>
              <div>
                <h4 class="font-bold text-white text-xs">Define Goals</h4>
                <p style="font-size: 10px;" class="text-gray-500">AI chatbot records organization profile</p>
              </div>
            </div>
            <div class="p-4 bg-black border border-darkBorder rounded-2xl flex items-center space-x-4">
              <div class="h-9 w-9 rounded-full bg-mediumPurple/10 text-softBlue flex items-center justify-center font-bold">2</div>
              <div>
                <h4 class="font-bold text-white text-xs">Ingest Ledger</h4>
                <p style="font-size: 10px;" class="text-gray-500">Drop CSV sheet or load demo database</p>
              </div>
            </div>
            <div class="p-4 bg-black border border-darkBorder rounded-2xl flex items-center space-x-4">
              <div class="h-9 w-9 rounded-full bg-royalBlue/10 text-softBlue flex items-center justify-center font-bold">3</div>
              <div>
                <h4 class="font-bold text-white text-xs">Anomaly Scan</h4>
                <p style="font-size: 10px;" class="text-gray-500">Compute z-scores for spending deviations</p>
              </div>
            </div>
            <div class="p-4 bg-black border border-darkBorder rounded-2xl flex items-center space-x-4">
              <div class="h-9 w-9 rounded-full bg-softBlue/10 text-softBlue flex items-center justify-center font-bold">4</div>
              <div>
                <h4 class="font-bold text-white text-xs">Forecast Models</h4>
                <p style="font-size: 10px;" class="text-gray-500">6-month ARIMA projection curves</p>
              </div>
            </div>
            <div class="p-4 bg-black border border-darkBorder rounded-2xl flex items-center space-x-4">
              <div class="h-9 w-9 rounded-full bg-mediumPurple/10 text-softBlue flex items-center justify-center font-bold">5</div>
              <div>
                <h4 class="font-bold text-white text-xs">AI Strategy</h4>
                <p style="font-size: 10px;" class="text-gray-500">Gemini audits metrics & structures SWOT</p>
              </div>
            </div>
            <div class="p-4 bg-black border border-darkBorder rounded-2xl flex items-center space-x-4">
              <div class="h-9 w-9 rounded-full bg-gradient-to-tr from-mediumPurple to-softBlue text-white flex items-center justify-center font-bold">6</div>
              <div>
                <h4 class="font-bold text-white text-xs">Interactive View</h4>
                <p style="font-size: 10px;" class="text-gray-500">Adjust simulator variables & export PDF</p>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- FOOTER -->
      <footer class="border-t border-darkBorder/30 py-8 bg-darkCard/20 w-full mt-auto">
        <div class="max-w-7xl mx-auto px-6 flex flex-col md:flex-row items-center justify-between text-xs text-gray-500 gap-4">
          <div class="flex items-center space-x-2">
            <i data-lucide="layers" class="h-4 w-4 text-softBlue"></i>
            <span>AI Organizational Analytics Dashboard. All rights reserved.</span>
          </div>
          <button onclick="document.getElementById('landing-hero').scrollIntoView({behavior: 'smooth'})" class="text-gray-400 hover:text-white flex items-center space-x-1">
            <span>Back to Top</span>
            <i data-lucide="arrow-up" class="h-3 w-3"></i>
          </button>
        </div>
      </footer>
    </div>


    <!-- AUTH VIEW -->
    <div id="view-auth" class="hidden min-h-screen flex flex-col justify-center items-center p-6 relative overflow-hidden">
      <!-- Starry / Glowing Background Blobs -->
      <div class="absolute top-1/3 left-1/4 w-72 h-72 bg-midnightPurple/20 rounded-full filter blur-[100px] pointer-events-none -z-10 animate-pulse"></div>
      <div class="absolute bottom-1/3 right-1/4 w-72 h-72 bg-royalBlue/15 rounded-full filter blur-[100px] pointer-events-none -z-10"></div>

      <button onclick="switchView('landing')" class="flex items-center space-x-3 mb-8 focus:outline-none hover:opacity-90 transition-opacity">
        <div class="h-9 w-9 rounded-lg bg-gradient-to-tr from-mediumPurple via-royalBlue to-softBlue flex items-center justify-center shadow-lg">
          <i data-lucide="bar-chart-3" class="h-5 w-5 text-white"></i>
        </div>
        <span class="font-outfit font-extrabold text-lg text-white block tracking-wide">ORGANALYTICS</span>
      </button>

      <!-- Panel: Login / Register card -->
      <div id="auth-panel-main" class="glass-panel w-full max-w-md rounded-3xl p-8 shadow-2xl border border-darkBorder glow-border flex flex-col">
        <div class="flex border-b border-darkBorder/60 mb-6 text-center">
          <button id="auth-tab-signin" onclick="setAuthMode(true)" class="flex-1 pb-3 text-sm font-semibold tracking-wide border-b-2 border-softBlue text-white transition-all">
            Sign In
          </button>
          <button id="auth-tab-signup" onclick="setAuthMode(false)" class="flex-1 pb-3 text-sm font-semibold tracking-wide border-b-2 border-transparent text-gray-500 hover:text-gray-300 transition-all">
            Create Account
          </button>
        </div>

        <h3 id="auth-title" class="text-2xl font-bold font-outfit text-white text-center mb-6">Log in</h3>
        <p id="auth-desc" class="text-xs text-gray-500 text-center -mt-4 mb-6">Enter credentials to access your insights history.</p>

        <div id="auth-error" class="hidden mb-6 p-4 bg-rose-500/10 border border-rose-500/20 rounded-xl flex items-start space-x-3 text-rose-400 text-xs">
          <i data-lucide="alert-circle" class="h-4.5 w-4.5 flex-shrink-0 mt-0.5"></i>
          <span id="auth-error-msg">Error details.</span>
        </div>

        <!-- Google button at the top if Sign Up -->
        <div id="google-btn-container-top" class="hidden">
          <button type="button" onclick="triggerGoogleLogin()" class="w-full mb-4 py-3 px-4 rounded-xl border border-gray-300 hover:bg-gray-50 bg-white flex items-center justify-center space-x-2.5 text-xs text-gray-700 font-bold transition-all shadow-md">
            <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
              <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
              <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.06H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.94l3.66-2.85z" fill="#FBBC05"/>
              <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.06l3.66 2.85c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
            </svg>
            <span class="text-gray-800">Sign up with Google</span>
          </button>

          <div class="flex items-center my-4 text-xs text-gray-500 font-semibold">
            <div class="flex-grow border-t border-darkBorder/40"></div>
            <span class="px-3">or with</span>
            <div class="flex-grow border-t border-darkBorder/40"></div>
          </div>
        </div>

        <form onsubmit="handleAuthSubmit(event)" class="space-y-4">
          <div id="auth-field-name" class="hidden space-y-1">
            <label class="text-xs font-semibold text-gray-400">Full Name</label>
            <input type="text" id="auth-name" placeholder="Name" class="w-full px-4 py-3 bg-black border border-darkBorder rounded-xl focus:outline-none focus:border-softBlue/60 text-sm text-white placeholder-gray-600 transition-colors" />
          </div>

          <div class="space-y-1">
            <label class="text-xs font-semibold text-gray-400">Email Address</label>
            <input type="email" id="auth-email" required placeholder="Email" class="w-full px-4 py-3 bg-black border border-darkBorder rounded-xl focus:outline-none focus:border-softBlue/60 text-sm text-white placeholder-gray-600 transition-colors" />
          </div>

          <div id="auth-field-password" class="space-y-1">
            <label class="text-xs font-semibold text-gray-400">Password</label>
            <div class="relative">
              <input type="password" id="auth-password" placeholder="Password" class="w-full pl-4 pr-10 py-3 bg-black border border-darkBorder rounded-xl focus:outline-none focus:border-softBlue/60 text-sm text-white placeholder-gray-600 transition-colors" />
              <button type="button" onclick="togglePasswordVisibility()" class="absolute inset-y-0 right-0 pr-3 flex items-center text-gray-500 hover:text-gray-300">
                <i id="auth-password-eye" data-lucide="eye" class="h-4.5 w-4.5"></i>
              </button>
            </div>
            <div class="flex justify-end pt-1">
              <button type="button" onclick="showForgotPasswordPanel(true)" id="auth-link-forgot" class="text-xs text-gray-400 hover:text-softBlue underline hover:no-underline transition-colors">Forgot password?</button>
            </div>
          </div>

          <!-- reCAPTCHA Mockup Box (Sign Up Only) -->
          <div id="auth-field-recaptcha" class="hidden py-2">
            <div class="border border-darkBorder bg-black/60 rounded-lg p-3 flex items-center justify-between max-w-xs">
              <div class="flex items-center space-x-3">
                <input type="checkbox" id="recaptcha-check" class="h-5 w-5 rounded border-darkBorder bg-black text-[#54E1EF] focus:ring-[#54E1EF]" />
                <label for="recaptcha-check" class="text-xs font-medium text-gray-300 select-none cursor-pointer">I'm not a robot</label>
              </div>
              <div class="flex flex-col items-center justify-center">
                <img src="https://www.gstatic.com/recaptcha/api2/logo_48.png" class="h-7 w-7 opacity-80" alt="reCAPTCHA" />
                <span style="font-size: 8px;" class="text-[8px] text-gray-500 font-mono mt-0.5">reCAPTCHA</span>
              </div>
            </div>
          </div>

          <button type="submit" id="auth-btn" class="w-full mt-6 py-3 px-4 rounded-xl bg-[#54E1EF] hover:bg-[#46C8D5] text-black font-bold flex items-center justify-center space-x-2 transition-all shadow-md">
            <span id="auth-btn-text">Continue</span>
            <i data-lucide="chevron-right" class="h-4.5 w-4.5"></i>
          </button>
        </form>

        <!-- Google button at bottom if Sign In -->
        <div id="google-btn-container-bottom" class="mt-4">
          <div class="flex items-center my-4 text-xs text-gray-500 font-semibold">
            <div class="flex-grow border-t border-darkBorder/40"></div>
            <span class="px-3">or</span>
            <div class="flex-grow border-t border-darkBorder/40"></div>
          </div>

          <button type="button" onclick="triggerGoogleLogin()" class="w-full py-3 px-4 rounded-xl border border-gray-300 hover:bg-gray-50 bg-white flex items-center justify-center space-x-2.5 text-xs text-gray-700 font-bold transition-all shadow-md">
            <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
              <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
              <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.06H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.94l3.66-2.85z" fill="#FBBC05"/>
              <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.06l3.66 2.85c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
            </svg>
            <span class="text-gray-800">Login with Google</span>
          </button>
        </div>

        <div class="text-center mt-6">
          <button type="button" id="auth-switch-link" onclick="setAuthMode(!isLoginMode)" class="text-xs text-[#54E1EF] hover:underline focus:outline-none">I don't have an account</button>
        </div>

        <p id="auth-terms-text" class="hidden text-center text-[10px] text-gray-500 mt-4 leading-relaxed">
          By signing up, you agree to the <span class="underline cursor-pointer">Terms of Service</span>.
        </p>
      </div>

      <!-- Panel: Forgot Password (hidden on load) -->
      <div id="auth-panel-forgot" class="hidden glass-panel w-full max-w-md rounded-3xl p-8 shadow-2xl border border-darkBorder glow-border animate-fade-in flex flex-col">
        <h3 class="text-2xl font-bold font-outfit text-white text-center mb-4">Reset Password</h3>
        
        <!-- Progress stepper mockup -->
        <div class="flex items-center justify-between mb-6 px-4">
          <div class="flex flex-col items-center">
            <span id="step-dot-1" class="h-6 w-6 rounded-full bg-[#54E1EF] text-black font-bold text-xs flex items-center justify-center shadow-md">1</span>
            <span class="text-[9px] text-gray-400 mt-1">Email</span>
          </div>
          <div class="flex-grow h-[2px] bg-darkBorder mx-2"></div>
          <div class="flex flex-col items-center">
            <span id="step-dot-2" class="h-6 w-6 rounded-full bg-black border border-darkBorder text-gray-500 font-bold text-xs flex items-center justify-center">2</span>
            <span class="text-[9px] text-gray-500 mt-1">Verify</span>
          </div>
          <div class="flex-grow h-[2px] bg-darkBorder mx-2"></div>
          <div class="flex flex-col items-center">
            <span id="step-dot-3" class="h-6 w-6 rounded-full bg-black border border-darkBorder text-gray-500 font-bold text-xs flex items-center justify-center">3</span>
            <span class="text-[9px] text-gray-500 mt-1">Reset</span>
          </div>
        </div>

        <div id="forgot-error" class="hidden mb-6 p-4 bg-rose-500/10 border border-rose-500/20 rounded-xl flex items-start space-x-3 text-rose-400 text-xs">
          <i data-lucide="alert-circle" class="h-4.5 w-4.5 flex-shrink-0 mt-0.5"></i>
          <span id="forgot-error-msg">Error details.</span>
        </div>
        
        <!-- Step 1: Request Code -->
        <form id="forgot-step-1" onsubmit="handleRequestResetCode(event)" class="space-y-4">
          <p class="text-gray-400 text-xs text-center leading-relaxed">Enter your registered email address below. We'll generate a verification code.</p>
          <div class="space-y-1">
            <label class="text-xs font-semibold text-gray-400">Email Address</label>
            <input type="email" id="forgot-email" required placeholder="Email" class="w-full px-4 py-3 bg-black border border-darkBorder rounded-xl focus:outline-none focus:border-softBlue/60 text-sm text-white placeholder-gray-600 transition-colors" />
          </div>
          <div class="flex space-x-3 pt-2">
            <button type="button" onclick="showForgotPasswordPanel(false)" class="flex-1 py-3 px-4 bg-black border border-darkBorder hover:bg-darkCard text-gray-300 font-bold rounded-xl text-xs transition-colors">
              Cancel
            </button>
            <button type="submit" class="flex-1 py-3 px-4 bg-[#54E1EF] hover:bg-[#46C8D5] text-black font-bold rounded-xl text-xs shadow-md">
              Send Code
            </button>
          </div>
        </form>

        <!-- Step 2: Input Code & Reset Password -->
        <form id="forgot-step-2" class="hidden space-y-4" onsubmit="handleResetPasswordSubmit(event)">
          <div class="p-3 bg-emerald-500/10 border border-emerald-500/20 rounded-xl text-emerald-400 text-xs text-center border-l-4 border-emerald-400">
            Verification code sent! (Mock bypass code: <strong>123456</strong>)
          </div>
          
          <div class="space-y-1">
            <label class="text-xs font-semibold text-gray-400">Verification Code</label>
            <input type="text" id="forgot-code" required placeholder="123456" class="w-full px-4 py-3 bg-black border border-darkBorder rounded-xl focus:outline-none focus:border-softBlue/60 text-sm text-white placeholder-gray-600 text-center tracking-widest font-mono" />
          </div>

          <div class="space-y-1">
            <label class="text-xs font-semibold text-gray-400">New Password</label>
            <input type="password" id="forgot-new-password" required placeholder="New Password" class="w-full px-4 py-3 bg-black border border-darkBorder rounded-xl focus:outline-none focus:border-softBlue/60 text-sm text-white placeholder-gray-600" />
          </div>

          <div class="flex space-x-3 pt-2">
            <button type="button" onclick="showForgotPasswordPanel(false)" class="flex-1 py-3 px-4 bg-black border border-darkBorder hover:bg-darkCard text-gray-300 font-bold rounded-xl text-xs transition-colors">
              Cancel
            </button>
            <button type="submit" class="flex-1 py-3 px-4 bg-[#54E1EF] hover:bg-[#46C8D5] text-black font-bold rounded-xl text-xs shadow-md">
              Reset Password
            </button>
          </div>
        </form>
      </div>
    </div>


    <!-- SHELL LAYOUT (FOR AUTHENTICATED VIEWS) -->
    <div id="app-shell" class="hidden min-h-screen flex text-gray-100 font-sans">
      
      <!-- SIDEBAR -->
      <aside class="w-64 bg-black border-r border-darkBorder flex flex-col justify-between h-screen sticky top-0">
        <div>
          <div class="p-6 border-b border-darkBorder flex items-center space-x-3">
            <div class="h-9 w-9 rounded-lg bg-gradient-to-tr from-mediumPurple via-royalBlue to-softBlue flex items-center justify-center shadow-lg">
              <i data-lucide="bar-chart-3" class="h-5 w-5 text-white"></i>
            </div>
            <div>
              <span class="font-outfit font-extrabold text-lg text-white block tracking-wide">ORGANALYTICS</span>
              <span class="text-[10px] text-softBlue font-mono font-bold tracking-widest uppercase">AI Engine</span>
            </div>
          </div>

          <nav class="p-4 space-y-1">
            <button id="nav-new" onclick="selectTab('new-analysis')" class="w-full flex items-center space-x-3 px-4 py-3 rounded-xl transition-all duration-200 text-sm font-medium text-gray-400 hover:bg-darkBorder/30 hover:text-gray-200">
              <i data-lucide="plus-circle" class="h-5 w-5"></i>
              <span>New Analysis</span>
            </button>
            <button id="nav-history" onclick="selectTab('history')" class="w-full flex items-center space-x-3 px-4 py-3 rounded-xl transition-all duration-200 text-sm font-medium text-white bg-gradient-to-r from-mediumPurple/10 to-royalBlue/10 border-l-4 border-mediumPurple">
              <i data-lucide="layout-dashboard" class="h-5 w-5"></i>
              <span>My Dashboards</span>
            </button>
            <button id="nav-about" onclick="selectTab('about')" class="w-full flex items-center space-x-3 px-4 py-3 rounded-xl transition-all duration-200 text-sm font-medium text-gray-400 hover:bg-darkBorder/30 hover:text-gray-200">
              <i data-lucide="help-circle" class="h-5 w-5"></i>
              <span>How it Works</span>
            </button>
          </nav>
        </div>

        <!-- PROFILE BLOCK LINK (View Profile) -->
        <div class="p-4 border-t border-darkBorder bg-darkCard/40">
          <div onclick="selectTab('profile')" class="flex items-center space-x-3 mb-4 cursor-pointer hover:bg-darkBorder/20 p-2 rounded-xl transition-all">
            <div id="user-avatar" class="h-10 w-10 rounded-full bg-gradient-to-br from-mediumPurple via-royalBlue to-softBlue flex items-center justify-center font-outfit font-bold text-white shadow-md">
              U
            </div>
            <div class="overflow-hidden flex-1">
              <span id="user-display-name" class="font-semibold text-sm text-gray-200 block truncate leading-tight">User Name</span>
              <span id="user-display-email" class="text-[10px] text-gray-500 block truncate">email@example.com</span>
            </div>
            <i data-lucide="chevron-right" class="h-4 w-4 text-gray-500"></i>
          </div>
          <button onclick="handleLogout()" class="w-full flex items-center justify-center space-x-2 py-2 px-4 rounded-lg border border-darkBorder hover:bg-rose-500/10 hover:border-rose-500/30 hover:text-rose-400 text-gray-400 text-xs font-semibold transition-all">
            <i data-lucide="log-out" class="h-4 w-4"></i>
            <span>Sign Out</span>
          </button>
        </div>
      </aside>

      <!-- CONTENT FRAME -->
      <div class="flex-grow flex flex-col min-h-screen bg-black">
        
        <!-- HEADER -->
        <header class="bg-black/60 backdrop-blur-md border-b border-darkBorder/60 py-4 px-8 flex items-center justify-between sticky top-0 z-10">
          <div>
            <h1 id="header-title" class="text-xl font-bold font-outfit text-white tracking-wide">Saved Audits</h1>
            <p class="text-xs text-gray-500 mt-0.5">AI-Powered Organizational Diagnostic</p>
          </div>
          <div class="flex items-center space-x-6">
            <div class="flex items-center space-x-2 text-gray-400 text-xs font-medium">
              <i data-lucide="calendar" class="h-4 w-4 text-softBlue"></i>
              <span id="current-date-str">Saturday, Jun 20, 2026</span>
            </div>
            <div onclick="selectTab('profile')" class="flex items-center space-x-2 border border-darkBorder bg-darkCard/50 py-1.5 px-3 rounded-full text-xs font-semibold text-gray-300 cursor-pointer hover:border-softBlue/30 transition-colors">
              <i data-lucide="user" class="h-3.5 w-3.5 text-royalBlue"></i>
              <span id="header-user-badge">User</span>
            </div>
          </div>
        </header>

        <!-- PANEL CONTAINER -->
        <main class="flex-grow p-8">

          <!-- PANEL: HISTORY LIST -->
          <div id="panel-history" class="space-y-8">
            <div class="flex flex-col md:flex-row justify-between items-start md:items-center border-b border-darkBorder/40 pb-6 gap-4">
              <div>
                <h2 class="text-3xl font-extrabold font-outfit text-white tracking-tight">Audit History</h2>
                <p class="text-sm text-gray-500 mt-1">Manage and reload previous organizational audits</p>
              </div>
              <div class="flex items-center space-x-3 w-full md:w-auto">
                <div class="relative flex-grow md:flex-grow-0 md:w-64">
                  <span class="absolute inset-y-0 left-0 pl-3 flex items-center text-gray-500">
                    <i data-lucide="search" class="h-4 w-4"></i>
                  </span>
                  <input type="text" id="history-search" oninput="handleHistorySearch(event)" placeholder="Search audits..." class="w-full pl-9 pr-4 py-2 bg-black border border-darkBorder rounded-xl text-xs text-white focus:outline-none focus:border-softBlue/60 placeholder-gray-600 transition-colors" />
                </div>
                <button onclick="selectTab('new-analysis')" class="px-5 py-2.5 bg-darkCard border border-darkBorder hover:border-softBlue/40 text-gray-200 text-xs font-semibold rounded-xl transition-all shadow-md flex-shrink-0">
                  New Audit
                </button>
              </div>
            </div>

            <!-- Filter pills -->
            <div class="flex flex-wrap gap-2 items-center">
              <span class="text-[10px] uppercase font-bold text-gray-500 tracking-wider mr-2">Filter Industry:</span>
              <button id="pill-all" onclick="filterHistoryIndustry('All')" class="px-3.5 py-1.5 rounded-full text-xs font-semibold bg-mediumPurple/20 text-softBlue border border-mediumPurple/40 transition-all">All</button>
              <button id="pill-retail" onclick="filterHistoryIndustry('Retail / E-commerce')" class="px-3.5 py-1.5 rounded-full text-xs font-semibold bg-black border border-darkBorder text-gray-400 hover:text-white transition-all">Retail</button>
              <button id="pill-saas" onclick="filterHistoryIndustry('SaaS Technology')" class="px-3.5 py-1.5 rounded-full text-xs font-semibold bg-black border border-darkBorder text-gray-400 hover:text-white transition-all">SaaS Tech</button>
              <button id="pill-health" onclick="filterHistoryIndustry('Healthcare')" class="px-3.5 py-1.5 rounded-full text-xs font-semibold bg-black border border-darkBorder text-gray-400 hover:text-white transition-all">Healthcare</button>
              <button id="pill-ent" onclick="filterHistoryIndustry('Entertainment')" class="px-3.5 py-1.5 rounded-full text-xs font-semibold bg-black border border-darkBorder text-gray-400 hover:text-white transition-all">Entertainment</button>
              <button id="pill-ops" onclick="filterHistoryIndustry('Logistics & Supply Chain')" class="px-3.5 py-1.5 rounded-full text-xs font-semibold bg-black border border-darkBorder text-gray-400 hover:text-white transition-all">Logistics</button>
            </div>

            <!-- Empty state fallback -->
            <div id="history-empty" class="hidden glass-panel rounded-2xl border border-darkBorder/50 p-12 text-center max-w-xl mx-auto space-y-6">
              <div class="h-14 w-14 rounded-full bg-darkBorder/40 border border-darkBorder flex items-center justify-center text-gray-400 mx-auto">
                <i data-lucide="layout-grid" class="h-7 w-7"></i>
              </div>
              <div class="space-y-2">
                <h3 class="font-outfit font-bold text-white text-lg">No Matching Audits Found</h3>
                <p class="text-gray-400 text-xs max-w-xs mx-auto leading-relaxed">
                  Adjust your search or filter settings, or start by submitting your company requirements.
                </p>
              </div>
              <button onclick="selectTab('new-analysis')" class="px-6 py-3 bg-gradient-to-r from-mediumPurple via-royalBlue to-softBlue text-white font-bold rounded-xl text-sm shadow-md hover:opacity-95">
                Create New Analysis
              </button>
            </div>

            <!-- Grid listing -->
            <div id="history-grid" class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <!-- Rendered via JS -->
            </div>
          </div>


          <!-- PANEL: NEW ANALYSIS (CONVERSATIONAL WITH INLINE FILE UPLOAD) -->
          <div id="panel-new-analysis" class="hidden space-y-6 h-[72vh] flex flex-col justify-between">
            <div id="chat-messages" class="flex-grow overflow-y-auto px-2 space-y-6">
              <!-- Chat bubbles rendered here -->
            </div>

            <div class="bg-darkCard border border-darkBorder rounded-2xl p-6 mt-4 glow-border">
              <div id="chat-input-text-container" class="flex space-x-3">
                <input type="text" id="chat-input-text" placeholder="Type here..." onkeydown="if(event.key==='Enter') sendChatInput()" class="flex-1 bg-black border border-darkBorder rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-softBlue/60 text-white placeholder-gray-600" />
                <button onclick="sendChatInput()" class="p-3 bg-mediumPurple rounded-xl text-white hover:opacity-90 transition-opacity shadow-md">
                  <i data-lucide="send" class="h-5 w-5"></i>
                </button>
              </div>
              <div id="chat-input-options-container" class="hidden flex flex-wrap gap-2">
                <!-- Rendered dynamically -->
              </div>
            </div>
          </div>


          <!-- PANEL: PROCESSING LOADER -->
          <div id="panel-processing" class="hidden h-[70vh] flex flex-col justify-center items-center">
            <div class="glass-panel max-w-lg w-full rounded-2xl p-8 border border-darkBorder text-center shadow-2xl relative glow-border">
              <div class="relative h-20 w-20 mx-auto mb-8 flex items-center justify-center">
                <div class="absolute inset-0 rounded-full border-4 border-darkBorder"></div>
                <div class="absolute inset-0 rounded-full border-4 border-t-softBlue border-r-mediumPurple animate-spin"></div>
                <i data-lucide="refresh-cw" class="h-8 w-8 text-softBlue animate-pulse"></i>
              </div>
              <h2 class="text-2xl font-extrabold font-outfit text-white tracking-wide">Executing Analytics Pipeline</h2>
              <p class="text-gray-400 text-xs mt-2 max-w-sm mx-auto">
                Please wait while we crunch numbers, compute ARIMA models, run anomaly checks, and draft strategic insights.
              </p>
              
              <div class="mt-8 space-y-4 text-left max-w-xs mx-auto">
                <div id="proc-step-0" class="flex items-center space-x-3 opacity-30">
                  <i data-lucide="database" class="h-5 w-5 text-softBlue"></i>
                  <span class="text-xs font-semibold">Ingesting historical database...</span>
                </div>
                <div id="proc-step-1" class="flex items-center space-x-3 opacity-30">
                  <i data-lucide="bar-chart-2" class="h-5 w-5 text-mediumPurple"></i>
                  <span class="text-xs font-semibold">Running statistical z-score audits...</span>
                </div>
                <div id="proc-step-2" class="flex items-center space-x-3 opacity-30">
                  <i data-lucide="trending-up" class="h-5 w-5 text-softBlue"></i>
                  <span class="text-xs font-semibold">Fitting Holt-Winters forecasting models...</span>
                </div>
                <div id="proc-step-3" class="flex items-center space-x-3 opacity-30">
                  <i data-lucide="sparkles" class="h-5 w-5 text-softBlue"></i>
                  <span class="text-xs font-semibold">Writing report details with Gemini...</span>
                </div>
              </div>
            </div>
          </div>


          <!-- PANEL: MAIN DASHBOARD -->
          <div id="panel-dashboard" class="hidden space-y-8">
            <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 border-b border-darkBorder/40 pb-6">
              <div>
                <span id="dash-report-id" class="text-xs font-bold text-softBlue uppercase tracking-wider font-mono">Report ID: #0</span>
                <div class="flex items-center space-x-3 mt-1">
                  <h2 id="dash-org-name" class="text-3xl font-extrabold font-outfit text-white tracking-tight">Company Dashboard</h2>
                  <button id="btn-edit-mode" onclick="toggleEditMode()" class="px-3 py-1 bg-darkCard border border-darkBorder hover:border-softBlue/40 rounded-lg text-xs font-semibold text-gray-400 hover:text-white flex items-center space-x-1.5 transition-all">
                    <i data-lucide="edit-3" class="h-3.5 w-3.5"></i>
                    <span id="btn-edit-text">Edit Insights</span>
                  </button>
                  <button id="btn-save-edits" onclick="saveDashboardEdits()" class="hidden px-3.5 py-1 bg-gradient-to-r from-mediumPurple to-royalBlue text-white rounded-lg text-xs font-bold shadow-md flex items-center space-x-1.5 transition-all">
                    <i data-lucide="check" class="h-3.5 w-3.5"></i>
                    <span>Save Changes</span>
                  </button>
                </div>
                <p id="dash-meta" class="text-sm text-gray-500 mt-1">Industry Context: Retail • Size: Medium</p>
              </div>
              <div class="flex items-center space-x-4 bg-darkCard/50 border border-darkBorder px-4 py-2 rounded-xl">
                <div class="flex flex-col space-y-1">
                  <span style="font-size: 9px;" class="text-[9px] uppercase font-bold text-gray-500 tracking-wider">Report PDF Theme</span>
                  <div class="flex items-center space-x-1.5" id="pdf-theme-selectors">
                    <button onclick="setPDFTheme('#1E3A8A', event)" class="w-3.5 h-3.5 rounded-full bg-blue-700 border-2 border-white focus:outline-none" title="Corporate Navy"></button>
                    <button onclick="setPDFTheme('#0D9488', event)" class="w-3.5 h-3.5 rounded-full bg-teal-600 border border-transparent focus:outline-none" title="Emerald Health"></button>
                    <button onclick="setPDFTheme('#4F46E5', event)" class="w-3.5 h-3.5 rounded-full bg-indigo-600 border border-transparent focus:outline-none" title="Tech Indigo"></button>
                    <button onclick="setPDFTheme('#EA580C', event)" class="w-3.5 h-3.5 rounded-full bg-orange-600 border border-transparent focus:outline-none" title="Warm Retail"></button>
                    <button onclick="setPDFTheme('#7C3AED', event)" class="w-3.5 h-3.5 rounded-full bg-purple-600 border border-transparent focus:outline-none" title="Creative Purple"></button>
                    <button onclick="setPDFTheme('#374151', event)" class="w-3.5 h-3.5 rounded-full bg-gray-700 border border-transparent focus:outline-none" title="Charcoal"></button>
                  </div>
                </div>
                <button onclick="downloadReportAsPDF()" class="flex items-center space-x-2 py-2.5 px-5 bg-gradient-to-r from-mediumPurple via-royalBlue to-softBlue hover:opacity-95 text-white font-bold rounded-xl text-xs shadow-md transition-all">
                  <i data-lucide="file-down" class="h-4 w-4"></i>
                  <span>Download PDF Report</span>
                </button>
              </div>
            </div>

            <!-- KPIs Row -->
            <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
              <!-- KPI Card 1 -->
              <div class="glass-panel rounded-2xl p-6 relative overflow-hidden glow-border">
                <div class="absolute top-0 left-0 right-0 h-[2px] bg-gradient-to-r from-transparent via-softBlue/40 to-transparent"></div>
                <div class="flex justify-between items-start">
                  <div>
                    <span class="text-xs font-semibold text-gray-500 uppercase tracking-wider block">Revenue (Analyzed Run)</span>
                    <span id="kpi-rev" class="text-3xl font-extrabold font-outfit text-white block mt-2 tracking-tight">$0</span>
                    <input type="text" id="edit-kpi-rev" class="hidden mt-2 bg-black border border-darkBorder rounded px-2 py-1 text-sm text-white w-full" />
                  </div>
                  <div class="h-10 w-10 rounded-xl bg-darkBorder/40 border border-darkBorder flex items-center justify-center text-softBlue">
                    <i data-lucide="dollar-sign" class="h-5 w-5"></i>
                  </div>
                </div>
                <div class="flex items-center space-x-2 mt-4 pt-4 border-t border-darkBorder/50">
                  <span class="text-xs text-gray-500 truncate">Total aggregated annual value</span>
                </div>
              </div>

              <!-- KPI Card 2 -->
              <div class="glass-panel rounded-2xl p-6 relative overflow-hidden glow-border">
                <div class="absolute top-0 left-0 right-0 h-[2px] bg-gradient-to-r from-transparent via-softBlue/40 to-transparent"></div>
                <div class="flex justify-between items-start">
                  <div>
                    <span class="text-xs font-semibold text-gray-500 uppercase tracking-wider block">YoY Expansion</span>
                    <span id="kpi-growth" class="text-3xl font-extrabold font-outfit text-white block mt-2 tracking-tight">0%</span>
                    <input type="text" id="edit-kpi-growth" class="hidden mt-2 bg-black border border-darkBorder rounded px-2 py-1 text-sm text-white w-full" />
                  </div>
                  <div class="h-10 w-10 rounded-xl bg-darkBorder/40 border border-darkBorder flex items-center justify-center text-softBlue">
                    <i data-lucide="trending-up" class="h-5 w-5"></i>
                  </div>
                </div>
                <div class="flex items-center space-x-2 mt-4 pt-4 border-t border-darkBorder/50">
                  <span class="text-[10px] font-bold px-2 py-0.5 rounded-full border text-emerald-400 bg-emerald-500/10 border-emerald-500/20" id="kpi-growth-badge">+0%</span>
                  <span class="text-xs text-gray-500 truncate">Calendar rate</span>
                </div>
              </div>

              <!-- KPI Card 3 -->
              <div class="glass-panel rounded-2xl p-6 relative overflow-hidden glow-border">
                <div class="absolute top-0 left-0 right-0 h-[2px] bg-gradient-to-r from-transparent via-softBlue/40 to-transparent"></div>
                <div class="flex justify-between items-start">
                  <div>
                    <span class="text-xs font-semibold text-gray-500 uppercase tracking-wider block">Efficiency Score</span>
                    <span id="kpi-eff" class="text-3xl font-extrabold font-outfit text-white block mt-2 tracking-tight">0/100</span>
                    <input type="text" id="edit-kpi-eff" class="hidden mt-2 bg-black border border-darkBorder rounded px-2 py-1 text-sm text-white w-full" />
                  </div>
                  <div class="h-10 w-10 rounded-xl bg-darkBorder/40 border border-darkBorder flex items-center justify-center text-softBlue">
                    <i data-lucide="activity" class="h-5 w-5"></i>
                  </div>
                </div>
                <div class="flex items-center space-x-2 mt-4 pt-4 border-t border-darkBorder/50">
                  <span class="text-xs text-gray-500 truncate">Budget utility index</span>
                </div>
              </div>

              <!-- KPI Card 4 -->
              <div class="glass-panel rounded-2xl p-6 relative overflow-hidden glow-border">
                <div class="absolute top-0 left-0 right-0 h-[2px] bg-gradient-to-r from-transparent via-softBlue/40 to-transparent"></div>
                <div class="flex justify-between items-start">
                  <div>
                    <span class="text-xs font-semibold text-gray-500 uppercase tracking-wider block">Risk Index</span>
                    <span id="kpi-risk" class="text-3xl font-extrabold font-outfit text-white block mt-2 tracking-tight">Low</span>
                    <input type="text" id="edit-kpi-risk" class="hidden mt-2 bg-black border border-darkBorder rounded px-2 py-1 text-sm text-white w-full" />
                  </div>
                  <div class="h-10 w-10 rounded-xl bg-darkBorder/40 border border-darkBorder flex items-center justify-center text-softBlue">
                    <i data-lucide="alert-triangle" class="h-5 w-5"></i>
                  </div>
                </div>
                <div class="flex items-center space-x-2 mt-4 pt-4 border-t border-darkBorder/50">
                  <span class="text-xs text-gray-500 truncate">Leverage profile limit</span>
                </div>
              </div>
            </div>

            <!-- SWOT Matrix Quadrant (Interactive, editable) -->
            <div class="glass-panel rounded-2xl border border-darkBorder/50 p-6 shadow-xl space-y-4">
              <div>
                <h3 class="font-outfit font-bold text-white text-lg flex items-center space-x-2">
                  <i data-lucide="award" class="h-5 w-5 text-softBlue animate-pulse"></i>
                  <span>SWOT Matrix Audit</span>
                </h3>
                <p class="text-xs text-gray-500">Interactive strengths, weaknesses, opportunities, and threats parameters (Double click values to edit)</p>
              </div>

              <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <!-- Strengths -->
                <div class="border border-darkBorder bg-darkCard/40 rounded-2xl p-5 border-l-4 border-emerald-500">
                  <span class="text-xs font-bold text-emerald-400 uppercase tracking-widest block font-mono">Strengths (Internal)</span>
                  <div id="swot-strengths" contenteditable="false" class="text-xs text-gray-400 mt-2 space-y-2 focus:outline-none">
                    <!-- Loaded dynamically -->
                  </div>
                </div>
                <!-- Weaknesses -->
                <div class="border border-darkBorder bg-darkCard/40 rounded-2xl p-5 border-l-4 border-rose-500">
                  <span class="text-xs font-bold text-rose-400 uppercase tracking-widest block font-mono">Weaknesses (Internal)</span>
                  <div id="swot-weaknesses" contenteditable="false" class="text-xs text-gray-400 mt-2 space-y-2 focus:outline-none">
                    <!-- Loaded dynamically -->
                  </div>
                </div>
                <!-- Opportunities -->
                <div class="border border-darkBorder bg-darkCard/40 rounded-2xl p-5 border-l-4 border-softBlue">
                  <span class="text-xs font-bold text-softBlue uppercase tracking-widest block font-mono">Opportunities (External)</span>
                  <div id="swot-opportunities" contenteditable="false" class="text-xs text-gray-400 mt-2 space-y-2 focus:outline-none">
                    <!-- Loaded dynamically -->
                  </div>
                </div>
                <!-- Threats -->
                <div class="border border-darkBorder bg-darkCard/40 rounded-2xl p-5 border-l-4 border-amber-500">
                  <span class="text-xs font-bold text-amber-500 uppercase tracking-widest block font-mono">Threats (External)</span>
                  <div id="swot-threats" contenteditable="false" class="text-xs text-gray-400 mt-2 space-y-2 focus:outline-none">
                    <!-- Loaded dynamically -->
                  </div>
                </div>
              </div>
            </div>

            <!-- Charts and Strategic text -->
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
              
              <!-- Left side: visual tab graphs -->
              <div class="lg:col-span-2 space-y-8">
                <div class="glass-panel rounded-2xl border border-darkBorder/50 p-6 shadow-xl">
                  <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center border-b border-darkBorder/40 pb-4 mb-6 gap-3">
                    <div>
                      <h3 class="font-outfit font-bold text-white text-lg">Statistical Visualizations</h3>
                      <p class="text-xs text-gray-500">Visual representations of metrics</p>
                    </div>
                    <div class="flex bg-darkBg/60 border border-darkBorder p-1 rounded-xl text-xs">
                      <button id="tab-btn-trend" onclick="switchChartTab('trend')" class="px-3 py-1.5 rounded-lg font-semibold bg-mediumPurple/20 text-softBlue border border-mediumPurple/40">
                        Trend & Forecast
                      </button>
                      <button id="tab-btn-dept" onclick="switchChartTab('dept')" class="px-3 py-1.5 rounded-lg font-semibold text-gray-400 hover:text-gray-200">
                        Departments
                      </button>
                      <button id="tab-btn-alloc" onclick="switchChartTab('alloc')" class="px-3 py-1.5 rounded-lg font-semibold text-gray-400 hover:text-gray-200">
                        Allocation
                      </button>
                    </div>
                  </div>

                  <!-- Graph container -->
                  <div class="h-80 w-full relative">
                    <canvas id="dashboardChart"></canvas>
                  </div>
                </div>

                <!-- Scenario builder / Simulator -->
                <div class="glass-panel rounded-2xl border border-darkBorder/50 p-6 shadow-xl space-y-6 glow-border-blue">
                  <div>
                    <h3 class="font-outfit font-bold text-white text-lg flex items-center space-x-2">
                      <i data-lucide="sliders" class="h-5 w-5 text-softBlue"></i>
                      <span>Organizational What-If Simulator</span>
                    </h3>
                    <p class="text-xs text-gray-500">Slide strategic investments to predict revenue changes based on driver importances</p>
                  </div>

                  <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                    <!-- Slider 1 -->
                    <div class="space-y-2">
                      <div class="flex justify-between text-xs font-semibold text-gray-300">
                        <span>Marketing Spend</span>
                        <span id="sim-val-mkt" class="text-softBlue">0%</span>
                      </div>
                      <input type="range" id="sim-slider-mkt" min="-50" max="100" value="0" oninput="updateScenarioSimulation()" class="w-full h-1 bg-darkBorder rounded-lg appearance-none cursor-pointer accent-softBlue" />
                      <span class="text-[10px] text-gray-500 block">Correlates directly to new traffic acquisition</span>
                    </div>

                    <!-- Slider 2 -->
                    <div class="space-y-2">
                      <div class="flex justify-between text-xs font-semibold text-gray-300">
                        <span>Product / R&D Focus</span>
                        <span id="sim-val-rd" class="text-softBlue">0%</span>
                      </div>
                      <input type="range" id="sim-slider-rd" min="-50" max="100" value="0" oninput="updateScenarioSimulation()" class="w-full h-1 bg-darkBorder rounded-lg appearance-none cursor-pointer accent-softBlue" />
                      <span class="text-[10px] text-gray-500 block">Calibrates release cycle & customer retention</span>
                    </div>

                    <!-- Slider 3 -->
                    <div class="space-y-2">
                      <div class="flex justify-between text-xs font-semibold text-gray-300">
                        <span>Sales Pipeline Conversion</span>
                        <span id="sim-val-sales" class="text-softBlue">0%</span>
                      </div>
                      <input type="range" id="sim-slider-sales" min="-50" max="100" value="0" oninput="updateScenarioSimulation()" class="w-full h-1 bg-darkBorder rounded-lg appearance-none cursor-pointer accent-softBlue" />
                      <span class="text-[10px] text-gray-500 block">Optimizes inbound lead conversion margins</span>
                    </div>
                  </div>

                  <div class="bg-black/60 border border-darkBorder rounded-xl p-4 flex items-center justify-between">
                    <div>
                      <span class="text-xs text-gray-500 uppercase tracking-widest font-semibold">Simulated Growth Output</span>
                      <div class="flex items-center space-x-3 mt-1">
                        <span id="sim-out-rev" class="text-2xl font-extrabold text-white font-outfit">$0</span>
                        <span id="sim-out-percent" class="text-xs font-bold text-emerald-400 bg-emerald-500/10 px-2 py-0.5 rounded-full border border-emerald-500/20">+0%</span>
                      </div>
                    </div>
                    <div class="text-right">
                      <span class="text-xs text-gray-500 uppercase tracking-widest font-semibold">Simulated ROI Ratio</span>
                      <span id="sim-out-roi" class="text-2xl font-extrabold text-softBlue font-outfit block mt-1">1.0x</span>
                    </div>
                  </div>
                </div>

                <!-- Anomalies segment -->
                <div class="glass-panel rounded-2xl border border-darkBorder/50 p-6 shadow-xl space-y-4">
                  <div>
                    <h3 class="font-outfit font-bold text-white text-lg">Ingested Data Anomalies</h3>
                    <p class="text-xs text-gray-500">Points of significant statistical variation from seasonal rolling medians</p>
                  </div>
                  <div id="dash-anomalies-list" class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <!-- Rendered via JS -->
                  </div>
                </div>
              </div>

              <!-- Right side: Gemini report text -->
              <div>
                <div class="glass-panel rounded-2xl border border-darkBorder/50 p-6 shadow-xl flex flex-col h-[544px] justify-between">
                  <div>
                    <div class="flex justify-between items-center border-b border-darkBorder/40 pb-4 mb-4">
                      <div>
                        <h3 class="font-outfit font-bold text-white text-lg flex items-center space-x-2">
                          <i data-lucide="sparkles" class="h-5 w-5 text-softBlue animate-pulse"></i>
                          <span>Gemini Strategic Report</span>
                        </h3>
                        <p class="text-xs text-gray-500">AI growth analysis context</p>
                      </div>
                    </div>

                    <!-- Inner report navigation -->
                    <div class="flex border-b border-darkBorder mb-4 text-xs font-semibold overflow-x-auto pb-1">
                      <button id="rep-tab-exec" onclick="switchReportTab('exec')" class="pb-1 pr-3 border-b-2 border-softBlue text-white">Executive</button>
                      <button id="rep-tab-swot" onclick="switchReportTab('swot')" class="pb-1 px-3 border-b-2 border-transparent text-gray-500">SWOT</button>
                      <button id="rep-tab-root" onclick="switchReportTab('root')" class="pb-1 px-3 border-b-2 border-transparent text-gray-500">Root Cause</button>
                      <button id="rep-tab-bench" onclick="switchReportTab('bench')" class="pb-1 pl-3 border-b-2 border-transparent text-gray-500">Benchmarks</button>
                    </div>

                    <!-- Render context text -->
                    <div id="dash-report-text-container" class="relative">
                      <div id="dash-report-text" class="text-xs text-gray-400 leading-relaxed overflow-y-auto h-80 pr-1 space-y-3 text-justify">
                        <!-- Rendered via JS -->
                      </div>
                      <textarea id="edit-report-text" class="hidden w-full h-80 bg-black border border-darkBorder rounded-xl p-3 text-xs text-white placeholder-gray-600 focus:outline-none focus:border-softBlue/60 resize-none"></textarea>
                    </div>
                  </div>
