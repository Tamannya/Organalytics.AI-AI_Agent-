# -----------------------------------------------------------------------------
# Environment Variables for AI Organizational Analytics Dashboard
# Copy this file to '.env' and populate with your credentials.
# -----------------------------------------------------------------------------

# 1. Gemini API Key
# Required to trigger requirements extraction and written growth audits.
# Get your key from: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# 2. JWT Session Security
# Provide a cryptographically secure random secret string for user sessions.
JWT_SECRET=your_custom_jwt_secret_key_here
