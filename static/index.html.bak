              <div class="grid grid-cols-2 gap-6 pt-6 border-t border-darkBorder/40 text-sm">
                <div>
                  <span class="text-gray-500 block text-xs uppercase tracking-wider font-semibold">Email Address</span>
                  <span id="profile-email" class="text-gray-200 mt-1 block">john@company.com</span>
                </div>
                <div>
                  <span class="text-gray-500 block text-xs uppercase tracking-wider font-semibold">Account Status</span>
                  <span class="text-emerald-400 mt-1 block font-semibold flex items-center"><span class="h-2 w-2 bg-emerald-400 rounded-full inline-block mr-1.5 animate-pulse"></span>Active</span>
                </div>
                <div>
                  <span class="text-gray-500 block text-xs uppercase tracking-wider font-semibold">Strategic Audits Ran</span>
                  <span id="profile-reports-count" class="text-gray-200 mt-1 block font-bold font-outfit">0 Audits</span>
                </div>
                <div>
                  <span class="text-gray-500 block text-xs uppercase tracking-wider font-semibold">API Model Integrations</span>
                  <span class="text-softBlue mt-1 block">Google Gemini v1.5 Flash</span>
                </div>
              </div>
            </div>

            <!-- Password Reset inside Profile -->
            <div class="glass-panel rounded-2xl border border-darkBorder/50 p-6 shadow-xl space-y-4">
              <h3 class="font-outfit font-bold text-white text-lg">Update Account Password</h3>
              
              <div id="profile-pass-success" class="hidden p-3 bg-emerald-500/10 border border-emerald-500/20 rounded-xl text-emerald-400 text-xs text-center">
                Password updated successfully!
              </div>

              <form onsubmit="handleProfilePasswordReset(event)" class="space-y-4">
                <div class="grid grid-cols-2 gap-4">
                  <div class="space-y-1">
                    <label class="text-xs font-semibold text-gray-400">Current Password</label>
                    <input type="password" required id="profile-cur-pass" placeholder="••••••••" class="w-full px-4 py-2.5 bg-black border border-darkBorder rounded-xl focus:outline-none focus:border-softBlue/60 text-xs text-white" />
                  </div>
                  <div class="space-y-1">
                    <label class="text-xs font-semibold text-gray-400">New Password</label>
                    <input type="password" required id="profile-new-pass" placeholder="••••••••" class="w-full px-4 py-2.5 bg-black border border-darkBorder rounded-xl focus:outline-none focus:border-softBlue/60 text-xs text-white" />
                  </div>
                </div>
                <button type="submit" class="px-5 py-2.5 bg-darkCard border border-darkBorder hover:border-softBlue/40 text-white rounded-xl text-xs font-semibold transition-all">
                  Update Password
                </button>
              </form>
            </div>
